{
  "name": "igd-discovery",
  "description": "Run upnpc -s inside a resolved namespace to inspect IGD discovery.",
  "required_inputs": ["namespace", "capture_destination", "capture_label", "capture_kind"],
  "probe_sequence": [
    {
      "id": "capture-igd-discovery",
      "type": "capture_command",
      "argv": ["ip", "netns", "exec", "{namespace}", "upnpc", "-s"],
      "destination": "{capture_destination}",
      "label": "{capture_label}",
      "kind": "{capture_kind}"
    }
  ]
}
