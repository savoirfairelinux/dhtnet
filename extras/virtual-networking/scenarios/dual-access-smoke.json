{
  "name": "dual-access-smoke",
  "description": "Bring up the dual-access topology and confirm the node prefers Wi-Fi while a standby mobile-like path also exists.",
  "topology": "dual-access",
  "lab": "dual-access",
  "fixtures": ["miniupnpd-wifi-router"],
  "fields": {
    "profile_before": "wifi-home",
    "profile_after": "mobile-standby"
  },
  "notes": [
    "This is a topology smoke scenario only; it does not yet apply impairments or trigger a route handover.",
    "A passing run confirms the harness can reproduce a preferred Wi-Fi path with a standby mobile-like path."
  ],
  "steps": [
    {
      "name": "inspect_node_routes",
      "probe": "capture-namespace-command",
      "inputs": {
        "namespace": {"role": "node"},
        "argv": ["ip", "route", "show"],
        "capture_destination": "node-routes.txt",
        "capture_label": "Node routes",
        "capture_kind": "state-dump"
      }
    },
    {
      "name": "discover_wifi_igd_from_node",
      "probe": "igd-discovery",
      "inputs": {
        "namespace": {"role": "node"},
        "capture_destination": "node-upnpc.txt",
        "capture_label": "Node IGD discovery",
        "capture_kind": "command-output"
      }
    },
    {
      "name": "inspect_wan_addresses",
      "probe": "capture-namespace-command",
      "inputs": {
        "namespace": {"role": "wan_client"},
        "argv": ["ip", "addr", "show"],
        "capture_destination": "wan-addresses.txt",
        "capture_label": "WAN addresses",
        "capture_kind": "state-dump"
      }
    }
  ]
}
