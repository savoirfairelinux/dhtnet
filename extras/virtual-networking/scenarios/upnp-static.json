{
  "name": "upnp-static",
  "description": "Bring up the baseline single-router UPnP lab and verify a real WAN-side dhtnet session plus the UPnP mapping it creates.",
  "topology": "single-router",
  "fixtures": ["local-bootstrap", "miniupnpd-edge-router"],
  "services": [
    {
      "name": "listener",
      "kind": "command",
      "role": "lan_node",
      "argv": [
        "{root}/lib/service_actions/launch-dsh-listener.sh",
        "--bootstrap",
        "{FIXTURE_LOCAL_BOOTSTRAP_BOOTSTRAP_HOST}"
      ],
      "readiness": { "type": "file", "timeout_s": 120 },
      "outputs": { "type": "json", "required": ["peer_id"] }
    }
  ],
  "notes": [
    "This is the baseline composition scenario: topology bring-up, reusable fixtures, managed dhtnet service launch, IGD discovery, WAN dhtnet roundtrip, and teardown.",
    "The runner starts a local OpenDHT bootstrap fixture and a miniupnpd router fixture directly instead of going through setup wrapper scripts.",
    "If your dhtnet binaries are not under <repo>/build, set DHTNET_BUILD_DIR before running the scenario."
  ],
  "steps": [
    {
      "name": "discover_igd_from_lan",
      "probe": "igd-discovery",
      "inputs": {
        "namespace": { "role": "lan_node" }
      }
    },
    {
      "name": "probe_dhtnet_from_wan",
      "probe": "dsh-roundtrip",
      "inputs": {
        "client_namespace": { "role": "wan_client" },
        "router_namespace": { "role": "edge_router" },
        "target_namespace": { "service": "listener" },
        "target_peer_id": { "service": "listener", "field": "peer_id" },
        "bootstrap_host": {
          "fixture": "local-bootstrap",
          "field": "bootstrap_host"
        },
        "bootstrap_port": {
          "fixture": "local-bootstrap",
          "field": "bootstrap_port"
        },
        "router_external_ip": {
          "fixture": "miniupnpd-edge-router",
          "field": "external_ip"
        }
      }
    }
  ]
}
