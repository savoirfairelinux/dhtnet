{
  "name": "dual-router-handover-smoke",
  "description": "Bring up the dual-router topology and confirm the node sees both routed uplinks and at least one discoverable IGD.",
  "topology": "dual-router-handover",
  "lab": "dual-router-handover",
  "fixtures": ["miniupnpd-uplink-a", "miniupnpd-uplink-b"],
  "notes": [
    "This is a topology smoke scenario only; it validates the reusable handover lab before route-swap automation is added.",
    "A passing run means the dual-uplink environment is reproducible and discoverable from the node side using topology roles and router fixtures."
  ],
  "steps": [
    {
      "name": "inspect_node_routes",
      "probe": "namespace-command",
      "inputs": {
        "namespace": {"role": "node"},
        "argv": ["ip", "route", "show"]
      },
      "capture": "node-routes.txt",
      "label": "Node routes",
      "kind": "state-dump"
    },
    {
      "name": "discover_igd_from_node",
      "probe": "igd-discovery",
      "inputs": {
        "namespace": {"role": "node"}
      },
      "capture": "node-upnpc.txt",
      "label": "Node IGD discovery",
      "kind": "command-output"
    },
    {
      "name": "inspect_wan_addresses",
      "probe": "namespace-command",
      "inputs": {
        "namespace": {"role": "wan_client"},
        "argv": ["ip", "addr", "show"]
      },
      "capture": "wan-addresses.txt",
      "label": "WAN addresses",
      "kind": "state-dump"
    }
  ]
}
