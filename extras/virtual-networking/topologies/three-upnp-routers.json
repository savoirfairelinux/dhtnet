{
  "name": "three-upnp-routers",
  "description": "Three DHTNet LAN nodes, each behind its own NAT/UPnP router, connected through a routed WAN namespace.",
  "defaults": {
    "NODE_A_NS": "node-a",
    "NODE_A_IFACE": "eth0",
    "NODE_A_IP_CIDR": "192.168.101.2/24",
    "NODE_A_GW": "192.168.101.1",
    "NODE_B_NS": "node-b",
    "NODE_B_IFACE": "eth0",
    "NODE_B_IP_CIDR": "192.168.102.2/24",
    "NODE_B_GW": "192.168.102.1",
    "NODE_C_NS": "node-c",
    "NODE_C_IFACE": "eth0",
    "NODE_C_IP_CIDR": "192.168.103.2/24",
    "NODE_C_GW": "192.168.103.1",
    "NODE_MULTICAST_CIDR": "224.0.0.0/4",
    "RTR_A_NS": "rtr-a",
    "RTR_A_IFACE_LAN": "veth-rtr-a-lan",
    "RTR_A_IFACE_WAN": "veth-rtr-a-wan",
    "RTR_A_LAN_IP_CIDR": "192.168.101.1/24",
    "RTR_A_WAN_IP_CIDR": "11.0.101.2/24",
    "RTR_A_EXT_IP": "11.0.101.2",
    "RTR_B_NS": "rtr-b",
    "RTR_B_IFACE_LAN": "veth-rtr-b-lan",
    "RTR_B_IFACE_WAN": "veth-rtr-b-wan",
    "RTR_B_LAN_IP_CIDR": "192.168.102.1/24",
    "RTR_B_WAN_IP_CIDR": "11.0.102.2/24",
    "RTR_B_EXT_IP": "11.0.102.2",
    "RTR_C_NS": "rtr-c",
    "RTR_C_IFACE_LAN": "veth-rtr-c-lan",
    "RTR_C_IFACE_WAN": "veth-rtr-c-wan",
    "RTR_C_LAN_IP_CIDR": "192.168.103.1/24",
    "RTR_C_WAN_IP_CIDR": "11.0.103.2/24",
    "RTR_C_EXT_IP": "11.0.103.2",
    "WAN_NS": "wan",
    "WAN_IFACE_A": "veth-wan-a",
    "WAN_IFACE_B": "veth-wan-b",
    "WAN_IFACE_C": "veth-wan-c",
    "WAN_A_IP": "11.0.101.1",
    "WAN_A_IP_CIDR": "11.0.101.1/24",
    "WAN_B_IP": "11.0.102.1",
    "WAN_B_IP_CIDR": "11.0.102.1/24",
    "WAN_C_IP": "11.0.103.1",
    "WAN_C_IP_CIDR": "11.0.103.1/24",
    "WAN_IP_CIDR": "11.0.101.1/24"
  },
  "roles": {
    "node_a": {
      "namespace": "{NODE_A_NS}"
    },
    "node_b": {
      "namespace": "{NODE_B_NS}"
    },
    "node_c": {
      "namespace": "{NODE_C_NS}"
    },
    "node_a_router": {
      "namespace": "{RTR_A_NS}"
    },
    "node_b_router": {
      "namespace": "{RTR_B_NS}"
    },
    "node_c_router": {
      "namespace": "{RTR_C_NS}"
    },
    "wan_client": {
      "namespace": "{WAN_NS}"
    }
  },
  "namespaces": [
    "{NODE_A_NS}",
    "{NODE_B_NS}",
    "{NODE_C_NS}",
    "{RTR_A_NS}",
    "{RTR_B_NS}",
    "{RTR_C_NS}",
    "{WAN_NS}"
  ],
  "operations": [
    {
      "type": "connect-veth",
      "ns_a": "{NODE_A_NS}",
      "iface_a": "{NODE_A_IFACE}",
      "ns_b": "{RTR_A_NS}",
      "iface_b": "{RTR_A_IFACE_LAN}"
    },
    {
      "type": "connect-veth",
      "ns_a": "{NODE_B_NS}",
      "iface_a": "{NODE_B_IFACE}",
      "ns_b": "{RTR_B_NS}",
      "iface_b": "{RTR_B_IFACE_LAN}"
    },
    {
      "type": "connect-veth",
      "ns_a": "{NODE_C_NS}",
      "iface_a": "{NODE_C_IFACE}",
      "ns_b": "{RTR_C_NS}",
      "iface_b": "{RTR_C_IFACE_LAN}"
    },
    {
      "type": "connect-veth",
      "ns_a": "{WAN_NS}",
      "iface_a": "{WAN_IFACE_A}",
      "ns_b": "{RTR_A_NS}",
      "iface_b": "{RTR_A_IFACE_WAN}"
    },
    {
      "type": "connect-veth",
      "ns_a": "{WAN_NS}",
      "iface_a": "{WAN_IFACE_B}",
      "ns_b": "{RTR_B_NS}",
      "iface_b": "{RTR_B_IFACE_WAN}"
    },
    {
      "type": "connect-veth",
      "ns_a": "{WAN_NS}",
      "iface_a": "{WAN_IFACE_C}",
      "ns_b": "{RTR_C_NS}",
      "iface_b": "{RTR_C_IFACE_WAN}"
    },
    {
      "type": "set-loopbacks-up",
      "namespaces": [
        "{NODE_A_NS}",
        "{NODE_B_NS}",
        "{NODE_C_NS}",
        "{RTR_A_NS}",
        "{RTR_B_NS}",
        "{RTR_C_NS}",
        "{WAN_NS}"
      ]
    },
    {
      "type": "configure-ipv4-interface",
      "ns": "{NODE_A_NS}",
      "iface": "{NODE_A_IFACE}",
      "cidr": "{NODE_A_IP_CIDR}"
    },
    {
      "type": "configure-ipv4-interface",
      "ns": "{NODE_B_NS}",
      "iface": "{NODE_B_IFACE}",
      "cidr": "{NODE_B_IP_CIDR}"
    },
    {
      "type": "configure-ipv4-interface",
      "ns": "{NODE_C_NS}",
      "iface": "{NODE_C_IFACE}",
      "cidr": "{NODE_C_IP_CIDR}"
    },
    {
      "type": "configure-ipv4-interface",
      "ns": "{RTR_A_NS}",
      "iface": "{RTR_A_IFACE_LAN}",
      "cidr": "{RTR_A_LAN_IP_CIDR}"
    },
    {
      "type": "configure-ipv4-interface",
      "ns": "{RTR_A_NS}",
      "iface": "{RTR_A_IFACE_WAN}",
      "cidr": "{RTR_A_WAN_IP_CIDR}"
    },
    {
      "type": "configure-ipv4-interface",
      "ns": "{RTR_B_NS}",
      "iface": "{RTR_B_IFACE_LAN}",
      "cidr": "{RTR_B_LAN_IP_CIDR}"
    },
    {
      "type": "configure-ipv4-interface",
      "ns": "{RTR_B_NS}",
      "iface": "{RTR_B_IFACE_WAN}",
      "cidr": "{RTR_B_WAN_IP_CIDR}"
    },
    {
      "type": "configure-ipv4-interface",
      "ns": "{RTR_C_NS}",
      "iface": "{RTR_C_IFACE_LAN}",
      "cidr": "{RTR_C_LAN_IP_CIDR}"
    },
    {
      "type": "configure-ipv4-interface",
      "ns": "{RTR_C_NS}",
      "iface": "{RTR_C_IFACE_WAN}",
      "cidr": "{RTR_C_WAN_IP_CIDR}"
    },
    {
      "type": "configure-ipv4-interface",
      "ns": "{WAN_NS}",
      "iface": "{WAN_IFACE_A}",
      "cidr": "{WAN_A_IP_CIDR}"
    },
    {
      "type": "configure-ipv4-interface",
      "ns": "{WAN_NS}",
      "iface": "{WAN_IFACE_B}",
      "cidr": "{WAN_B_IP_CIDR}"
    },
    {
      "type": "configure-ipv4-interface",
      "ns": "{WAN_NS}",
      "iface": "{WAN_IFACE_C}",
      "cidr": "{WAN_C_IP_CIDR}"
    },
    {
      "type": "add-default-route",
      "ns": "{NODE_A_NS}",
      "via": "{NODE_A_GW}",
      "dev": "{NODE_A_IFACE}"
    },
    {
      "type": "add-default-route",
      "ns": "{NODE_B_NS}",
      "via": "{NODE_B_GW}",
      "dev": "{NODE_B_IFACE}"
    },
    {
      "type": "add-default-route",
      "ns": "{NODE_C_NS}",
      "via": "{NODE_C_GW}",
      "dev": "{NODE_C_IFACE}"
    },
    {
      "type": "add-default-route",
      "ns": "{RTR_A_NS}",
      "via": "{WAN_A_IP}",
      "dev": "{RTR_A_IFACE_WAN}"
    },
    {
      "type": "add-default-route",
      "ns": "{RTR_B_NS}",
      "via": "{WAN_B_IP}",
      "dev": "{RTR_B_IFACE_WAN}"
    },
    {
      "type": "add-default-route",
      "ns": "{RTR_C_NS}",
      "via": "{WAN_C_IP}",
      "dev": "{RTR_C_IFACE_WAN}"
    },
    {
      "type": "add-device-route",
      "ns": "{NODE_A_NS}",
      "destination": "{NODE_MULTICAST_CIDR}",
      "dev": "{NODE_A_IFACE}"
    },
    {
      "type": "add-device-route",
      "ns": "{NODE_B_NS}",
      "destination": "{NODE_MULTICAST_CIDR}",
      "dev": "{NODE_B_IFACE}"
    },
    {
      "type": "add-device-route",
      "ns": "{NODE_C_NS}",
      "destination": "{NODE_MULTICAST_CIDR}",
      "dev": "{NODE_C_IFACE}"
    },
    {
      "type": "setup-basic-ipv4-router",
      "ns": "{WAN_NS}"
    },
    {
      "type": "setup-basic-nat-router",
      "ns": "{RTR_A_NS}",
      "lan_iface": "{RTR_A_IFACE_LAN}",
      "wan_iface": "{RTR_A_IFACE_WAN}"
    },
    {
      "type": "setup-basic-nat-router",
      "ns": "{RTR_B_NS}",
      "lan_iface": "{RTR_B_IFACE_LAN}",
      "wan_iface": "{RTR_B_IFACE_WAN}"
    },
    {
      "type": "setup-basic-nat-router",
      "ns": "{RTR_C_NS}",
      "lan_iface": "{RTR_C_IFACE_LAN}",
      "wan_iface": "{RTR_C_IFACE_WAN}"
    }
  ]
}
